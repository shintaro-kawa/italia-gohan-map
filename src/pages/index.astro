---
import Layout from '@/layouts/Layout.astro';
import FilterBar from '@/components/FilterBar.astro';
import RestaurantCard from '@/components/RestaurantCard.astro';
import MapView from '@/components/Map.astro';
import RestaurantModal from '@/components/RestaurantModal.astro';
import ChatPanel from '@/components/ChatPanel.astro';
import { getRestaurants } from '@/data/loader';

const restaurants = await getRestaurants();
---

<Layout title="イタリアご飯マップ">
  <header class="app-header">
    <h1>イタリアご飯マップ</h1>
    <span class="card-meta">{restaurants.length} 店舗</span>
  </header>

  <main>
    <FilterBar />

    <div class="tab-bar" role="tablist" aria-label="表示切替">
      <button type="button" role="tab" data-tab="list" aria-selected="true">📋 リスト</button>
      <button type="button" role="tab" data-tab="map" aria-selected="false">🗺 地図</button>
    </div>

    <div class="split">
      <section data-pane="list" aria-label="店舗リスト">
        <div class="cards" id="cards">
          {restaurants.map((r) => <RestaurantCard restaurant={r} />)}
        </div>
        <div class="empty" id="empty-state" hidden>条件に一致する店舗がありません</div>
      </section>

      <section data-pane="map" hidden aria-label="地図表示">
        <MapView restaurants={restaurants} />
      </section>
    </div>
  </main>

  <RestaurantModal restaurants={restaurants} />
  <ChatPanel />
</Layout>

<script>
  type Visit = 'all' | 'visited' | 'unvisited';
  type ExcludeTag = 'tourist' | 'mediocre' | 'skip';
  type Sort = 'recommended' | 'rating' | 'name' | 'recent';
  type State = {
    cities: Set<string>;
    genres: Set<string>;
    visit: Visit;
    exclude: Set<ExcludeTag>;
    query: string;
    sort: Sort;
  };

  const state: State = {
    cities: new Set(),
    genres: new Set(),
    visit: 'all',
    exclude: new Set(),
    query: '',
    sort: 'recommended',
  };

  function readFromUrl() {
    const params = new URLSearchParams(location.search);
    const cities = params.get('city');
    const genres = params.get('genre');
    const visit = params.get('visit') as Visit | null;
    const exclude = params.get('exclude');
    const q = params.get('q');
    const sort = params.get('sort') as Sort | null;
    if (cities) cities.split(',').forEach((c) => state.cities.add(c));
    if (genres) genres.split(',').forEach((g) => state.genres.add(g));
    if (visit === 'visited' || visit === 'unvisited' || visit === 'all') state.visit = visit;
    if (exclude) {
      exclude.split(',').forEach((e) => {
        if (e === 'tourist' || e === 'mediocre' || e === 'skip') state.exclude.add(e);
      });
    }
    if (q) state.query = q;
    if (sort === 'rating' || sort === 'name' || sort === 'recent' || sort === 'recommended') state.sort = sort;
  }

  function writeToUrl() {
    const params = new URLSearchParams();
    if (state.cities.size) params.set('city', [...state.cities].join(','));
    if (state.genres.size) params.set('genre', [...state.genres].join(','));
    if (state.visit !== 'all') params.set('visit', state.visit);
    if (state.exclude.size) params.set('exclude', [...state.exclude].join(','));
    if (state.query) params.set('q', state.query);
    if (state.sort !== 'recommended') params.set('sort', state.sort);
    const next = params.toString();
    const url = next ? `${location.pathname}?${next}` : location.pathname;
    history.replaceState(null, '', url);
  }

  function syncUI() {
    document.querySelectorAll('[data-filter-group="city"] .chip').forEach((el) => {
      const v = el.getAttribute('data-value');
      if (v) el.setAttribute('aria-pressed', state.cities.has(v) ? 'true' : 'false');
    });
    document.querySelectorAll('[data-filter-group="genre"] .chip').forEach((el) => {
      const v = el.getAttribute('data-value');
      if (v) el.setAttribute('aria-pressed', state.genres.has(v) ? 'true' : 'false');
    });
    document.querySelectorAll('[data-filter-group="visit"] button').forEach((el) => {
      const v = el.getAttribute('data-value');
      el.setAttribute('aria-pressed', v === state.visit ? 'true' : 'false');
    });
    document.querySelectorAll('[data-filter-group="exclude"] .chip').forEach((el) => {
      const v = el.getAttribute('data-value');
      if (v) el.setAttribute('aria-pressed', state.exclude.has(v as ExcludeTag) ? 'true' : 'false');
    });
    const input = document.getElementById('search-input');
    if (input instanceof HTMLInputElement && input.value !== state.query) input.value = state.query;
    const clearBtn = document.getElementById('search-clear');
    if (clearBtn) clearBtn.hidden = state.query.length === 0;
    const select = document.getElementById('sort-select');
    if (select instanceof HTMLSelectElement && select.value !== state.sort) select.value = state.sort;
  }

  function applyToCards() {
    const cards = document.querySelectorAll<HTMLElement>('.card');
    const query = state.query.trim().toLowerCase();
    let visibleCount = 0;
    cards.forEach((card) => {
      const city = card.dataset.city ?? '';
      const genre = card.dataset.genre ?? '';
      const visited = card.dataset.visited === 'true';
      const isTourist = card.dataset.tourist === 'true';
      const isMediocre = card.dataset.mediocre === 'true';
      const isSkip = card.dataset.skip === 'true';
      const search = card.dataset.search ?? '';
      const cityOk = state.cities.size === 0 || state.cities.has(city);
      const genreOk = state.genres.size === 0 || state.genres.has(genre);
      const visitOk =
        state.visit === 'all' || (state.visit === 'visited' && visited) || (state.visit === 'unvisited' && !visited);
      const excludeOk =
        !(state.exclude.has('tourist') && isTourist) &&
        !(state.exclude.has('mediocre') && isMediocre) &&
        !(state.exclude.has('skip') && isSkip);
      const queryOk = query.length === 0 || search.includes(query);
      const show = cityOk && genreOk && visitOk && excludeOk && queryOk;
      card.hidden = !show;
      if (show) visibleCount++;
    });
    const empty = document.getElementById('empty-state');
    if (empty) empty.hidden = visibleCount > 0;
  }

  function applySort() {
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.card'));
    const compare = (a: HTMLElement, b: HTMLElement): number => {
      const ratingA = Number(a.dataset.sortRating ?? -1);
      const ratingB = Number(b.dataset.sortRating ?? -1);
      const verdictA = Number(a.dataset.sortVerdict ?? 0);
      const verdictB = Number(b.dataset.sortVerdict ?? 0);
      const nameA = a.dataset.sortName ?? '';
      const nameB = b.dataset.sortName ?? '';
      const analyzedA = a.dataset.sortAnalyzed ?? '';
      const analyzedB = b.dataset.sortAnalyzed ?? '';
      switch (state.sort) {
        case 'rating':
          return ratingB - ratingA || verdictB - verdictA || nameA.localeCompare(nameB);
        case 'name':
          return nameA.localeCompare(nameB);
        case 'recent':
          return analyzedB.localeCompare(analyzedA) || nameA.localeCompare(nameB);
        case 'recommended':
        default:
          return verdictB - verdictA || ratingB - ratingA || nameA.localeCompare(nameB);
      }
    };
    cards.sort(compare).forEach((card, idx) => {
      card.style.order = String(idx);
    });
  }

  function dispatchFilter() {
    document.dispatchEvent(
      new CustomEvent('filter:change', {
        detail: {
          cities: [...state.cities],
          genres: [...state.genres],
          visit: state.visit,
        },
      }),
    );
  }

  function update() {
    syncUI();
    applyToCards();
    applySort();
    writeToUrl();
    dispatchFilter();
  }

  document.addEventListener('click', (e) => {
    const target = e.target;
    if (!(target instanceof HTMLElement)) return;

    const chip = target.closest('[data-filter-group="city"] .chip, [data-filter-group="genre"] .chip');
    if (chip instanceof HTMLElement) {
      e.stopPropagation();
      const group = chip.parentElement?.getAttribute('data-filter-group');
      const value = chip.getAttribute('data-value');
      if (!group || !value) return;
      const set = group === 'city' ? state.cities : state.genres;
      if (set.has(value)) set.delete(value);
      else set.add(value);
      update();
      return;
    }

    const visitBtn = target.closest('[data-filter-group="visit"] button');
    if (visitBtn instanceof HTMLElement) {
      e.stopPropagation();
      const value = visitBtn.getAttribute('data-value') as Visit | null;
      if (value) {
        state.visit = value;
        update();
      }
      return;
    }

    if (target.closest('[data-filter-reset]')) {
      e.stopPropagation();
      state.cities.clear();
      state.genres.clear();
      state.visit = 'all';
      state.exclude.clear();
      state.query = '';
      state.sort = 'recommended';
      update();
      return;
    }

    if (target.id === 'search-clear') {
      e.stopPropagation();
      state.query = '';
      update();
      return;
    }

    const tabBtn = target.closest('[role="tab"]');
    if (tabBtn instanceof HTMLElement) {
      const tab = tabBtn.getAttribute('data-tab');
      document.querySelectorAll('[role="tab"]').forEach((t) => {
        t.setAttribute('aria-selected', t === tabBtn ? 'true' : 'false');
      });
      document.querySelectorAll('[data-pane]').forEach((p) => {
        if (p instanceof HTMLElement) {
          p.hidden = p.getAttribute('data-pane') !== tab;
        }
      });
      if (tab === 'map') {
        window.dispatchEvent(new Event('resize'));
      }
    }
  });

  // 検索入力（インクリメンタル、軽くデバウンス）
  let searchTimer: number | undefined;
  const searchInput = document.getElementById('search-input');
  if (searchInput instanceof HTMLInputElement) {
    searchInput.addEventListener('input', () => {
      if (searchTimer) window.clearTimeout(searchTimer);
      searchTimer = window.setTimeout(() => {
        state.query = searchInput.value;
        update();
      }, 80);
    });
  }

  // ソート選択
  const sortSelect = document.getElementById('sort-select');
  if (sortSelect instanceof HTMLSelectElement) {
    sortSelect.addEventListener('change', () => {
      const v = sortSelect.value;
      if (v === 'rating' || v === 'name' || v === 'recent' || v === 'recommended') {
        state.sort = v;
        update();
      }
    });
  }

  readFromUrl();
  update();
</script>
