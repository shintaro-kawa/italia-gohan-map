---
import { CITIES, GENRES } from '@/types/restaurant';
---

<section class="filter-bar" aria-label="絞り込み">
  <div class="filter-row filter-row-top">
    <div class="search-wrap">
      <input
        type="search"
        id="search-input"
        class="search-input"
        placeholder="店名・エリア・タグで検索…"
        autocomplete="off"
        aria-label="検索"
      />
      <button type="button" id="search-clear" class="search-clear" aria-label="検索クリア" hidden>×</button>
    </div>
    <label class="sort-wrap">
      <span class="filter-label">並び替え</span>
      <select id="sort-select" class="sort-select" aria-label="並び替え">
        <option value="recommended">おすすめ順</option>
        <option value="rating">評価順</option>
        <option value="name">名前順</option>
        <option value="recent">新着順</option>
      </select>
    </label>
  </div>

  <div class="filter-row" data-filter-group="city" role="group" aria-label="都市">
    <span class="filter-label">都市</span>
    {
      CITIES.map((c) => (
        <button type="button" class="chip" data-value={c.value} aria-pressed="false">
          {c.label}
        </button>
      ))
    }
  </div>

  <div class="filter-row" data-filter-group="genre" role="group" aria-label="ジャンル">
    <span class="filter-label">ジャンル</span>
    {
      GENRES.map((g) => (
        <button type="button" class="chip" data-value={g.value} aria-pressed="false">
          {g.label}
        </button>
      ))
    }
  </div>

  <div class="filter-row">
    <span class="filter-label">訪問</span>
    <div class="visit-toggle" data-filter-group="visit" role="group" aria-label="訪問状態">
      <button type="button" data-value="all" aria-pressed="true">すべて</button>
      <button type="button" data-value="visited" aria-pressed="false">訪問済み</button>
      <button type="button" data-value="unvisited" aria-pressed="false">未訪問</button>
    </div>
  </div>

  <div class="filter-row" data-filter-group="exclude" role="group" aria-label="除外">
    <span class="filter-label">除外</span>
    <button type="button" class="chip" data-value="tourist" aria-pressed="false">観光客向け</button>
    <button type="button" class="chip" data-value="mediocre" aria-pressed="false">味の懸念</button>
    <button type="button" class="chip" data-value="skip" aria-pressed="false">skip 判定</button>
    <button type="button" class="reset-btn" data-filter-reset>リセット</button>
  </div>
</section>
