---
import type { Restaurant } from '@/types/restaurant';
import {
  CONCERN_LABELS,
  HIGHLIGHT_LABELS,
  cityLabel,
  genreLabel,
  topConcern,
  topHighlight,
  verdictMeta,
} from '@/types/restaurant';

interface Props {
  restaurant: Restaurant;
}

const { restaurant } = Astro.props;
const meta = [cityLabel(restaurant.city), restaurant.area, restaurant.priceRange].filter(Boolean).join(' ・ ');
const verdict = restaurant.verdict ? verdictMeta(restaurant.verdict) : undefined;
const concern = topConcern(restaurant.concerns);
const highlight = topHighlight(restaurant.highlights);

const concernSeverity = concern?.severity ?? null;

const hasTouristConcern = (restaurant.concerns ?? []).some(
  (c) => c.type === 'tourist-oriented' && (c.severity === 'medium' || c.severity === 'high'),
);
const hasMediocreConcern = (restaurant.concerns ?? []).some(
  (c) => c.type === 'mediocre-food' && (c.severity === 'medium' || c.severity === 'high'),
);
const isSkip = restaurant.verdict === 'skip';

const searchableText = [
  restaurant.name,
  restaurant.area,
  restaurant.address,
  restaurant.comment,
  (restaurant.tags ?? []).join(' '),
  (restaurant.highlights ?? []).map((h) => h.note ?? '').join(' '),
  (restaurant.concerns ?? []).map((c) => c.note ?? '').join(' '),
]
  .filter((s): s is string => Boolean(s))
  .join(' ')
  .toLowerCase();

const VERDICT_RANK: Record<string, number> = { recommended: 4, neutral: 3, caution: 2, skip: 1 };
const verdictRank = restaurant.verdict ? VERDICT_RANK[restaurant.verdict] ?? 0 : 0;
---

<button
  type="button"
  class={`card ${restaurant.visited ? 'is-visited' : 'is-unvisited'}`}
  data-restaurant-id={restaurant.id}
  data-city={restaurant.city}
  data-genre={restaurant.genre}
  data-visited={restaurant.visited ? 'true' : 'false'}
  data-verdict={restaurant.verdict ?? ''}
  data-tourist={hasTouristConcern ? 'true' : 'false'}
  data-mediocre={hasMediocreConcern ? 'true' : 'false'}
  data-skip={isSkip ? 'true' : 'false'}
  data-concerns={(restaurant.concerns ?? []).map((c) => `${c.type}:${c.severity}`).join(',')}
  data-search={searchableText}
  data-sort-name={restaurant.name.toLowerCase()}
  data-sort-rating={restaurant.rating ?? -1}
  data-sort-verdict={verdictRank}
  data-sort-analyzed={restaurant.lastAnalyzed ?? ''}
>
  <h3 class="card-title">
    {verdict && <span class="verdict-badge" aria-label={`評価: ${verdict.label}`}>{verdict.emoji}</span>}
    <span class="card-name">{restaurant.name}</span>
    {restaurant.visited && <span class="visited-badge" aria-label="訪問済み">訪問済み</span>}
  </h3>
  <p class="card-meta">{meta}</p>
  <div class="card-chips">
    <span class="genre-pill">{genreLabel(restaurant.genre)}</span>
    {
      highlight && (
        <span class="highlight-chip" title={highlight.note ?? ''}>
          + {HIGHLIGHT_LABELS[highlight.type]}
        </span>
      )
    }
    {
      concern && (
        <span class={`concern-chip severity-${concernSeverity}`} title={concern.note ?? ''}>
          ! {CONCERN_LABELS[concern.type]}
        </span>
      )
    }
  </div>
</button>
